{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/[locale]",
      "regex": "^/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPlocale": "nxtPlocale"
      },
      "namedRegex": "^/(?<nxtPlocale>[^/]+?)(?:/)?$"
    },
    {
      "page": "/[locale]/about",
      "regex": "^/([^/]+?)/about(?:/)?$",
      "routeKeys": {
        "nxtPlocale": "nxtPlocale"
      },
      "namedRegex": "^/(?<nxtPlocale>[^/]+?)/about(?:/)?$"
    },
    {
      "page": "/[locale]/blog",
      "regex": "^/([^/]+?)/blog(?:/)?$",
      "routeKeys": {
        "nxtPlocale": "nxtPlocale"
      },
      "namedRegex": "^/(?<nxtPlocale>[^/]+?)/blog(?:/)?$"
    },
    {
      "page": "/[locale]/blog/[slug]",
      "regex": "^/([^/]+?)/blog/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPlocale": "nxtPlocale",
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/(?<nxtPlocale>[^/]+?)/blog/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/[locale]/careers",
      "regex": "^/([^/]+?)/careers(?:/)?$",
      "routeKeys": {
        "nxtPlocale": "nxtPlocale"
      },
      "namedRegex": "^/(?<nxtPlocale>[^/]+?)/careers(?:/)?$"
    },
    {
      "page": "/[locale]/collection",
      "regex": "^/([^/]+?)/collection(?:/)?$",
      "routeKeys": {
        "nxtPlocale": "nxtPlocale"
      },
      "namedRegex": "^/(?<nxtPlocale>[^/]+?)/collection(?:/)?$"
    },
    {
      "page": "/[locale]/collection/[slug]",
      "regex": "^/([^/]+?)/collection/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPlocale": "nxtPlocale",
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/(?<nxtPlocale>[^/]+?)/collection/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/[locale]/contact",
      "regex": "^/([^/]+?)/contact(?:/)?$",
      "routeKeys": {
        "nxtPlocale": "nxtPlocale"
      },
      "namedRegex": "^/(?<nxtPlocale>[^/]+?)/contact(?:/)?$"
    },
    {
      "page": "/[locale]/product/[id]",
      "regex": "^/([^/]+?)/product/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPlocale": "nxtPlocale",
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/(?<nxtPlocale>[^/]+?)/product/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/[locale]/warranty",
      "regex": "^/([^/]+?)/warranty(?:/)?$",
      "routeKeys": {
        "nxtPlocale": "nxtPlocale"
      },
      "namedRegex": "^/(?<nxtPlocale>[^/]+?)/warranty(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/admin/blog",
      "regex": "^/admin/blog(?:/)?$",
